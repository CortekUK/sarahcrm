NEXT_PUBLIC_SUPABASE_URL=https://owjnsljovmaaxgxpxxtw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# OpenAI — powers the AI email template builder
OPENAI_API_KEY=sk-...
# Resend — test email sends from the template editor
RESEND_API_KEY=re_...
FROM_EMAIL=hello@example.com

# DocuSign (eSignature) — server-only. Demo/sandbox values shown as defaults.
# Get these from https://developers.docusign.com → Apps and Keys.
DOCUSIGN_INTEGRATION_KEY=            # Integration Key (client id) GUID
DOCUSIGN_USER_ID=                    # API Username / user id GUID (NOT your email)
DOCUSIGN_ACCOUNT_ID=                 # API Account ID GUID
# RSA private key. Paste the whole PEM; if single-line, escape newlines as \n.
DOCUSIGN_PRIVATE_KEY=
DOCUSIGN_BASE_PATH=https://demo.docusign.net       # prod: https://www.docusign.net
DOCUSIGN_OAUTH_BASE=account-d.docusign.com         # prod: account.docusign.com
DOCUSIGN_REDIRECT_URI=https://sarahcrm.vercel.app/api/admin/docusign/consent
# Real-time status: DocuSign pushes envelope events to <APP_URL>/api/docusign/webhook.
# Set a random secret (verifies inbound calls). Webhooks only fire on a public URL,
# not localhost — locally the app auto-refreshes status on page load instead.
DOCUSIGN_CONNECT_SECRET=
DOCUSIGN_WEBHOOK_URL=                                # optional; overrides the derived URL
